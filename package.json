{
  "name": "your-energy",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Your Energy — adaptive fitness exercises catalog. Team project for the MSc in Software Engineering & AI at Neoversity (GoIT), vanilla stack.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{js,scss}\" \"*.{js,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{js,scss}\" \"*.{js,json,md}\"",
    "prepare": "husky"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "izitoast": "^1.4.0",
    "modern-normalize": "^3.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "globals": "^15.14.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.3.0",
    "prettier": "^3.4.2",
    "sass": "^1.83.0",
    "vite": "^6.0.7"
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{scss,json,md}": [
      "prettier --write"
    ]
  }
}
