{
  "name": "go-fit",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "GoFit — adaptive fitness exercises catalog. Team project for the MSc in Software Engineering & AI at Neoversity (GoIT), vanilla stack.",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "check": "astro check",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,scss,astro}\" \"*.{js,mjs,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,scss,astro}\" \"*.{js,mjs,json,md}\"",
    "prepare": "husky"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.3",
    "@fontsource/dm-sans": "^5.2.8",
    "astro": "^7.0.4",
    "axios": "^1.7.9",
    "izitoast": "^1.4.0",
    "modern-normalize": "^3.0.1"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@eslint/js": "^9.17.0",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "globals": "^15.14.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^15.3.0",
    "prettier": "^3.4.2",
    "prettier-plugin-astro": "^0.14.1",
    "sass": "^1.83.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vitest": "^4.1.9"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{astro,scss,json,md}": [
      "prettier --write"
    ]
  }
}
