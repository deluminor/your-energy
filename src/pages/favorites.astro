---
import DailyNorm from '../components/daily-norm/DailyNorm.astro';
import FavoritesList from '../components/exercise-card/FavoritesList.astro';
import PhotoCard from '../components/photo-card/PhotoCard.astro';
import Quote from '../components/quote/Quote.astro';
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'Favorites — Your Energy';
const description = 'Your favorite exercises from the Your Energy catalog.';
---

<BaseLayout title={title} description={description} robots="noindex, follow">
  <main>
    <section class="favorites">
      <div class="container">
        <h1 class="section-title favorites__title">Favorites</h1>

        <div class="favorites__body">
          <aside class="favorites__aside">
            <div class="favorites__aside-quote">
              <Quote />
            </div>

            <div class="favorites__aside-bottom">
              <div class="favorites__aside-norm">
                <DailyNorm compact />
              </div>

              <div class="favorites__aside-photo">
                <PhotoCard />
              </div>
            </div>
          </aside>

          <div class="favorites__content">
            <FavoritesList />
          </div>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<style lang="scss">
  @use '../styles/abstracts' as *;

  .favorites {
    padding-block: 40px;

    &__title {
      margin-bottom: 32px;
    }

    &__body {
      display: flex;
      flex-direction: column;
      gap: 20px;

      @include respond($bp-tablet) {
        gap: 32px;
      }

      @include respond($bp-desktop) {
        display: grid;
        grid-template-columns: minmax(0, 1fr) minmax(0, 2fr);
        align-items: start;
        gap: 32px;
      }
    }

    &__aside {
      display: flex;
      flex-direction: column;
      gap: 20px;
      min-width: 0;
    }

    &__aside-quote {
      min-width: 0;

      :global(.quote) {
        height: 100%;
      }
    }

    &__aside-bottom {
      display: flex;
      flex-direction: column;
      gap: 20px;
      min-width: 0;

      @include respond($bp-desktop) {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        align-items: stretch;
        gap: 20px;
      }
    }

    &__aside-norm,
    &__aside-photo {
      min-width: 0;
    }

    &__aside-photo {
      :global(.promo-card-picture) {
        width: 100%;
        max-width: none;
        height: 100%;
        min-height: 141px;
        margin-inline: 0;
        aspect-ratio: unset;
      }
    }

    &__content {
      display: flex;
      flex-direction: column;
      min-width: 0;
    }
  }
</style>
