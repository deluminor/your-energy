---
import Breadcrumb from '@/components/breadcrumb/Breadcrumb.astro';
import CategoryList from '@/components/category-list/CategoryList.astro';
import DailyNorm from '@/components/daily-norm/DailyNorm.astro';
import ExerciseList from '@/components/exercise-list/ExerciseList.astro';
import Filters from '@/components/filters/Filters.astro';
import Hero from '@/components/hero/Hero.astro';
import Pagination from '@/components/pagination/Pagination.astro';
import PhotoCard from '@/components/photo-card/PhotoCard.astro';
import Quote from '@/components/quote/Quote.astro';
import Search from '@/components/search/Search.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { withBase, withBaseSrcSet } from '@/utils/withBase';

const title = 'GoFit';
const description =
  'GoFit — catalog of fitness exercises with filters, favorites and daily motivation.';

const heroMainMobSrc = withBase(
  'images/women-sportswear-working-out-outdoors-mob@1x.webp',
);
const heroMainMobSrcset = withBaseSrcSet(
  'images/women-sportswear-working-out-outdoors-mob@1x.webp 1x, images/women-sportswear-working-out-outdoors-mob@2x.webp 2x',
);
const heroMainTabSrc = withBase(
  'images/women-sportswear-working-out-outdoors-tab@1x.webp',
);
const heroMainTabSrcset = withBaseSrcSet(
  'images/women-sportswear-working-out-outdoors-tab@1x.webp 1x, images/women-sportswear-working-out-outdoors-tab@2x.webp 2x',
);
const heroMainDeskSrc = withBase(
  'images/women-sportswear-working-out-outdoors-desk@1x.webp',
);
const heroMainDeskSrcset = withBaseSrcSet(
  'images/women-sportswear-working-out-outdoors-desk@1x.webp 1x, images/women-sportswear-working-out-outdoors-desk@2x.webp 2x',
);
---

<BaseLayout title={title} description={description}>
  <link
    slot="head"
    rel="preload"
    as="image"
    href={heroMainMobSrc}
    imagesrcset={heroMainMobSrcset}
    media="(max-width: 767px)"
    fetchpriority="high"
  />
  <link
    slot="head"
    rel="preload"
    as="image"
    href={heroMainTabSrc}
    imagesrcset={heroMainTabSrcset}
    media="(min-width: 768px) and (max-width: 1157px)"
    fetchpriority="high"
  />
  <link
    slot="head"
    rel="preload"
    as="image"
    href={heroMainDeskSrc}
    imagesrcset={heroMainDeskSrcset}
    media="(min-width: 1158px)"
    fetchpriority="high"
  />

  <main>
    <Hero />

    <section class="exercises">
      <div class="container">
        <div class="exercises__head">
          <Breadcrumb />
          <div class="exercises__controls">
            <Search />
            <Filters />
          </div>
        </div>

        <div class="exercises__layout">
          <aside class="exercises__aside">
            <div class="exercises__aside-quote">
              <Quote />
            </div>
            <div class="exercises__aside-photo">
              <PhotoCard />
            </div>
            <div class="exercises__aside-norm">
              <DailyNorm />
            </div>
          </aside>

          <div class="exercises__content">
            <CategoryList />
            <ExerciseList />
            <Pagination />
          </div>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<style lang="scss">
  @use '../styles/abstracts' as *;

  .exercises {
    padding-block: 40px;

    &__head {
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      gap: 20px;
      margin-bottom: 32px;

      @include respond($bp-desktop) {
        flex-direction: row;
        justify-content: space-between;
        align-items: center;
        gap: 24px;
      }
    }

    &__controls {
      display: flex;
      flex-direction: column;
      gap: 16px;
      width: 100%;

      @include respond($bp-tablet) {
        flex-direction: row;
        align-items: center;
        gap: 24px;
      }

      @include respond($bp-desktop) {
        width: auto;
        justify-content: flex-end;
      }
    }

    &__layout {
      display: flex;
      flex-direction: column;
      gap: 20px;

      @include respond($bp-tablet) {
        gap: 32px;
      }

      @include respond($bp-desktop) {
        display: grid;
        grid-template-columns: minmax(0, 1fr) minmax(0, 2fr);
        align-items: start;
        gap: 32px;
      }
    }

    &__aside {
      order: 2;
      display: flex;
      flex-direction: column;
      gap: 20px;
      width: 100%;

      &-quote,
      &-norm,
      &-photo {
        grid-column: unset;
        grid-row: unset;
        width: 100%;
      }

      &-photo {
        width: 100%;
        margin-inline: auto;
        display: block;
        flex-shrink: 0;
      }

      @include respond($bp-tablet) {
        display: grid;
        grid-template-columns: 1fr 288px;
        grid-template-rows: 249px auto;
        gap: 20px;
        align-items: stretch;

        &-quote {
          grid-column: 1;
          grid-row: 1;
          width: 100%;
          height: 100%;

          :global(> *) {
            height: 100%;
          }
        }

        &-photo {
          grid-column: 2;
          grid-row: 1;
          max-width: 288px;
          height: 100%;
          margin-inline: unset;
        }

        &-norm {
          grid-column: 1;
          grid-row: 2;
          width: 100%;
          max-width: 400px;
          align-self: start;
        }
      }

      @include respond($bp-desktop) {
        order: unset;
        display: flex;
        flex-direction: column;
        gap: 20px;

        &-quote,
        &-norm,
        &-photo {
          grid-column: unset !important;
          grid-row: unset !important;
          width: 100% !important;
          height: auto !important;
          max-width: unset !important;
        }

        &-norm {
          max-width: unset !important;
        }
      }
    }

    &__content {
      order: 1;
      display: flex;
      flex-direction: column;

      @include respond($bp-desktop) {
        order: unset;
      }
    }
  }
</style>
