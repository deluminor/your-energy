<footer class="footer">
  <div class="container footer__container" data-component="footer">
    <div class="footer__top">
      <div class="footer__brand">
        <a class="footer__logo" href="/" aria-label="Go to home page">
          <svg class="footer__logo-icon" width="132" height="24">
            <use href="/sprite.svg#icon-logo"></use>
          </svg>
        </a>

        <ul class="footer__socials" aria-label="Social links">
          <li class="footer__social-item">
            <a
              class="footer__social-link"
              href="https://www.facebook.com/goITclub/"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Facebook"
            >
              <svg class="footer__social-icon" width="24" height="24">
                <use href="/sprite.svg#icon-facebook"></use>
              </svg>
            </a>
          </li>

          <li class="footer__social-item">
            <a
              class="footer__social-link"
              href="https://www.instagram.com/goitclub/"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Instagram"
            >
              <svg class="footer__social-icon" width="24" height="24">
                <use href="/sprite.svg#icon-instagram"></use>
              </svg>
            </a>
          </li>

          <li class="footer__social-item">
            <a
              class="footer__social-link"
              href="https://www.youtube.com/c/GoIT"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="YouTube"
            >
              <svg class="footer__social-icon" width="24" height="24">
                <use href="/sprite.svg#icon-youtube"></use>
              </svg>
            </a>
          </li>
        </ul>
      </div>

      <div class="footer__promo">
        <h2 class="footer__title">
          Transforming your <em class="footer__title-accent">body</em> shape with
          us
        </h2>

        <div class="footer__subscribe">
          <p class="footer__subscribe-text">
            Subscribe and learn about new exercises!
          </p>

          <form class="footer__form" data-footer-form novalidate>
            <label class="visually-hidden" for="footer-email">Email</label>

            <input
              class="footer__input"
              id="footer-email"
              name="email"
              type="email"
              placeholder="Email"
              required
              pattern="^\w+(\.\w+)?@[a-zA-Z_]+?\.[a-zA-Z]{2,3}$"
            />

            <button class="footer__button" type="submit">Send</button>
          </form>
        </div>
      </div>
    </div>

    <div class="footer__bottom">
      <p class="footer__copyright">Your Energy. All rights reserved.</p>

      <div class="footer__policy">
        <a class="footer__policy-link" href="#">Privacy Policy</a>
        <span class="footer__policy-separator">/</span>
        <a class="footer__policy-link" href="#">Terms of Service</a>
      </div>

      <p class="footer__year">©2026</p>
    </div>
  </div>
</footer>

<script>
  import { initFooter } from './footer.client.js';

  initFooter(document.querySelector('[data-component="footer"]'));
</script>
