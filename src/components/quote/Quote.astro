      <path
        d="M0 18V10.5C0 7 1 4.2 2.8 2.3C4.5.5 6.8 0 9 0v3.6c-1.7 0-3 .5-4 1.4C4.1 6 3.6 7.4 3.6 9H7.4v9H0ZM14.8 18V10.5c0-3.5 1-6.3 2.8-8.2C19.3.5 21.6 0 23.8 0v3.6c-1.7 0-3 .5-4 1.4-1 1-1.4 2.4-1.4 4h3.8v9h-6.4Z"
