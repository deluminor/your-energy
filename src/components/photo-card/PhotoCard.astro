---
import { withBase, withBaseSrcSet } from '../../utils/withBase';

const desktopSrcset = withBaseSrcSet(
  'images/quote-main-img.jpg, images/quote-main-img@2x.jpg 2x',
);
const tabletSrcset = withBaseSrcSet(
  'images/quote-main-tablet.jpg, images/quote-main-tablet@2x.jpg 2x',
);
const mobileSrc = withBase('images/quote-main-mobile.jpg');
const mobileSrcset = withBaseSrcSet('images/quote-main-mobile@2x.jpg 2x');
---

<picture class="promo-card-picture">
  <source media="(min-width: 1440px)" srcset={desktopSrcset} />

  <source media="(min-width: 768px)" srcset={tabletSrcset} />

  <img
    class="promo-card-img"
    src={mobileSrc}
    srcset={mobileSrcset}
    alt="Promo training motivation"
    loading="lazy"
  />
</picture>

<style lang="scss">
  @use '../../styles/abstracts' as *;

  .promo-card-picture {
    display: block;
    width: 100%;
    aspect-ratio: 335 / 242;
    overflow: hidden;
    border-radius: 20px;
    margin-inline: auto;
    flex-shrink: 0;

    @include respond($bp-tablet) {
      max-width: 288px;
      aspect-ratio: unset;
      height: 100%;
    }

    @include respond($bp-desktop) {
      max-width: 444px;
      aspect-ratio: 444 / 242;
    }
  }

  .promo-card-img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    flex-shrink: 0;
  }
</style>
